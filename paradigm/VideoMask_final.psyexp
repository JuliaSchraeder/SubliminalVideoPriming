  <Routines>
    <Routine name="Intro">
      <CodeComponent name="code">
        <Param name="Before Experiment" updates="constant" val="from psychopy import parallel&amp;#10;block_num = 0&amp;#10;&amp;#10;&amp;#10;#Scanner Wait = 2&amp;#10;#Jitter Start = 5&amp;#10;#Fixcross Start = 10&amp;#10;#Primer Start = ID_Primer (120-140)&amp;#10;#Mask Start = 20&amp;#10;&amp;#10;#Movie = ID_Target (150-160) (171 bei example)&amp;#10;#Slider = 170&amp;#10;#Response Start = 30&amp;#10;#Keypress Korrekt = 40&amp;#10;#KeyPress notcorrect= 45&amp;#10;#Keypress sad = 50&amp;#10;#Keypress neutral = 60&amp;#10;#Keypress happy = 70&amp;#10;#Keypress none = 80&amp;#10;&amp;#10;#Slider minus = 180&amp;#10;#Slider plus = 190&amp;#10;#Noslider Rating = 81&amp;#10;#Exp Start = 90&amp;#10;#Pause Start = 100&amp;#10;#Ende = 110" valType="extendedCode"/>
        <Param name="Before JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin Experiment" updates="constant" val="# Hide mouse&amp;#10;win.mouseVisible = False                                                        &amp;#10;&amp;#10;#Response for slider&amp;#10;slider_resp_response = keyboard.Keyboard()&amp;#10;&amp;#10;#Write Trigger File&amp;#10;#triggerName ='VideoMask_EEG_Trigger'&amp;#10;#filenametrigger = _thisDir + os.sep + u'data/%s_%s_%s' % (expInfo['participant'], triggerName, expInfo['date'])&amp;#10;#TriggerExp = data.ExperimentHandler(name=expName, version='04.02.20',&amp;#10;#    extraInfo=expInfo, runtimeInfo=None,&amp;#10;#    originPath='C:\\Users\\juhoffmann\\Desktop\\Paradigmen\\02_VideoMask\\VideoMask_120Hz_18_05_21.py',&amp;#10;#    savePickle=False, saveWideText=True,&amp;#10;#    dataFileName=filenametrigger)&amp;#10;&amp;#10;# Address EEG Trigger #&amp;#10;p_port_EEG= parallel.ParallelPort(address='0x3FE8') # Scanner&amp;#10;#p_port_EEG= parallel.ParallelPort(address='0x4FF7')   # EEG Room&amp;#10;#p_port_EEG.setData(0) &amp;#10;&amp;#10;&amp;#10;def sendTrigger(code): &amp;#10;    #print(code)&amp;#10;    #eegtriggertime = 0                                                          # Reset timing&amp;#10;    #eegtriggertime = core.getTime()                                             # Get Time of EEG Trigger&amp;#10;    &amp;#10;    win.callOnFlip(p_port_EEG.setData, int(code))&amp;#10;    core.wait(0.02)                                                       # Wait for 0.02 seconds&amp;#10;    p_port_EEG.setData(0)                                                      # Reset Trigger, set all pins to zero&amp;#10;    &amp;#10;    #TriggerExp.addData('EEG_trigger_time', eegtriggertime)                      # Save Time of EEG Trigger&amp;#10;    #TriggerExp.addData('EEG_trigger_number', code)                              # Save send EEG Trigger code&amp;#10;    #TriggerExp.nextEntry()&amp;#10;&amp;#10;&amp;#10;#Wait for Scanner&amp;#10;text_wait = visual.TextStim(win=win, name='text_wait',&amp;#10;    text='Warten auf Scanner...',&amp;#10;    font='Arial',&amp;#10;    pos=(0, 0), height=0.06, wrapWidth=None, ori=0, &amp;#10;    color='white', colorSpace='rgb', opacity=1, &amp;#10;    languageStyle='LTR',&amp;#10;    depth=0.0);&amp;#10;&amp;#10;#Set first MR Trigger&amp;#10;mr_trigger_number = []                                                          # array for MR scanner trigger&amp;#10;mr_trigger_time = []                                                            # saved at the end of the script&amp;#10;ScannerKeyboard = keyboard.Keyboard()                                           # keyboard for Scanner Trigger&amp;#10;count_mr_trigger = 0                                                            # counts amount of MR scanner trigger, starts with zero&amp;#10;start_trigger = ScannerKeyboard.getKeys(keyList=['a'], waitRelease = False)     # experiment starts with MR Scanner a &amp;#10;&amp;#10;# Draw waiting Screen until a is send&amp;#10;while len(start_trigger) == 0:                                                  # if no trigger was send show:&amp;#10;    text_wait.draw()                                                            # Text &quot;Warten auf Scanner&quot; &amp;#10;    win.flip()&amp;#10;    start_trigger = ScannerKeyboard.getKeys(keyList=['a'], waitRelease = False) # show text_wait until one &quot;a&quot; was pressed&amp;#10;    if len(start_trigger) ==1:&amp;#10;        sendTrigger(2)&amp;#10;# Get timing information and store trigger number&amp;#10;onset = core.getTime()                                                          # get Onset time&amp;#10;count_mr_trigger = count_mr_trigger + 1                                         # count MR Scanner trigger, start with 1&amp;#10;mr_trigger_time.append(onset)                                                   # append onset time in mr_trigger_time list&amp;#10;mr_trigger_number.append(count_mr_trigger)                                      # append trigger number in mr_trigger_number list&amp;#10;count_mr_trigger = count_mr_trigger + 1                                         # counts trigger&amp;#10;&amp;#10;# Save time and number of MR Trigger&amp;#10;thisExp.addData('MR_trigger_time', mr_trigger_time[0])                          # save trigger time of onset&amp;#10;thisExp.addData('MR_trigger_number', mr_trigger_number[0])                      # save trigger number" valType="extendedCode"/>
        <Param name="Begin JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin JS Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin Routine" updates="constant" val="" valType="extendedCode"/>
