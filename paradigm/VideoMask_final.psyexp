        <Param name="Each Frame" updates="constant" val="    if len(theseKeys) == 1:&amp;#10;        #sendTrigger(30)&amp;#10;        if key_resp.keys == &quot;7&quot;:&amp;#10;            sendTrigger(50)&amp;#10;        if key_resp.keys == &quot;8&quot;:&amp;#10;            sendTrigger(60)&amp;#10;        if key_resp.keys == &quot;9&quot;:&amp;#10;            sendTrigger(70)" valType="extendedCode"/>
