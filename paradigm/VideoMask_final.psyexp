    <Routine name="introcode">
      <CodeComponent name="code_2">
        <Param name="Before Experiment" updates="constant" val="#Set Framerate for Timing&amp;#10;hz120 = 1 #1&amp;#10;&amp;#10;#Set framerate for jitter                                                       # ms*framerate_factor=frames&amp;#10;framerate = 60*hz120                                                            # set framerate to get exact jitter time and save it in csv data&amp;#10;framerate_factor = framerate/1000                                               # 0.12 for 120 Hz&amp;#10;&amp;#10;#Set Timing for Routines in frames&amp;#10;startTime = 60*hz120                                                           # 3.000 ms/1s       welcome time and time before starting the first block&amp;#10;instruction = 300*hz120                                                         # 5.000 Ms          show instruction&amp;#10;cross300 = 18*hz120                                                             # 300 ms            fixcross&amp;#10;#primeTime1 = 1*hz120                                                           # 16,6 ms           primer strongly masked&amp;#10;#primeTime2 = 9*hz120                                                           # 150 ms            primer weakly maked #120Hz = 141, also 17 frames&amp;#10;scrambledTime = 4*hz120                                                         # 66ms ms             mask time #120Hz = 41, also 5 frames&amp;#10;targettime = 18*hz120                                                           # 300 ms            target time&amp;#10;responseTime = 90*hz120                                                         # 1.500 ms          time to response&amp;#10;jittermintime = 60*hz120                                                        # 1.000 ms          minimal jitter time&amp;#10;jittermaxtime = 120*hz120                                                       # 2.000 ms          maximal jitter time&amp;#10;maxBreakTime = 1200*hz120                                                       # 20.000 ms/2s      maximal break between blocks&amp;#10;ende = 600*hz120                                                                # 10.000 ms         Endbildschirm wird angezeigt&amp;#10;&amp;#10;# Conditions &amp;#10;num_possible_example = 9                                                        # total number of example images in the study&amp;#10;num_example = 5#5                                                                 # number of example items used&amp;#10;num_items = 360                                                                 # total number of experiment images in the study&amp;#10;num_study = 10#20                                                                 # number of study items used in one block#later 120 pro block&amp;#10;block_ans = 3#3                                                                   # number of blocks, starting with block 1&amp;#10;&amp;#10;text_height = 0.06&amp;#10;stimulis_size =(0.400, 0.484) #(0.529, 0.625)" valType="extendedCode"/>
        <Param name="Before JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin JS Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="Code Type" updates="None" val="Py" valType="str"/>
        <Param name="Each Frame" updates="constant" val="" valType="extendedCode"/>
        <Param name="Each JS Frame" updates="constant" val="" valType="extendedCode"/>
        <Param name="End Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="End JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="End JS Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="End Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="disabled" updates="None" val="False" valType="bool"/>
        <Param name="name" updates="None" val="code_2" valType="code"/>
      </CodeComponent>
    </Routine>
    <Routine name="trial_example">
      <CodeComponent name="code_ex">
        <Param name="Before Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Before JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin JS Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin Routine" updates="constant" val="#event.clearEvents('keyboard')&amp;#10;#slider.markerPos = 5&amp;#10;&amp;#10;slider_resp_response.rt = []&amp;#10;_slider_resp_response_allKeys = []&amp;#10;slider_resp_response.keys = [] &amp;#10;&amp;#10;slider.reset()&amp;#10;event.clearEvents('slider_resp_response')&amp;#10;slider.markerPos = 5" valType="extendedCode"/>
        <Param name="Code Type" updates="None" val="Py" valType="str"/>
        <Param name="Each Frame" updates="constant" val="#keys = event.getKeys()&amp;#10;&amp;#10;#if len(keys):&amp;#10;#    if '7' in keys:&amp;#10;#        slider.markerPos = slider.markerPos - 1&amp;#10;#    elif '8' in keys:&amp;#10;#        slider.markerPos = slider.markerPos  + 1 &amp;#10;&amp;#10;keys = slider_resp_response.getKeys(keyList=['7', '9'], waitRelease=False)&amp;#10;_slider_resp_response_allKeys.extend(keys) # put pressed keys in list&amp;#10;if len(keys) == 1:&amp;#10;    if len(_slider_resp_response_allKeys):&amp;#10;        slider_resp_response.keys = _slider_resp_response_allKeys[0].name  # just the first key pressed&amp;#10;        slider_resp_response.rt = _slider_resp_response_allKeys[0].rt #rt of first press&amp;#10;    if '7' in keys:&amp;#10;        slider.markerPos = slider.markerPos - 1&amp;#10;        sendTrigger(responseratingminus)&amp;#10;    elif '9' in keys:&amp;#10;        slider.markerPos = slider.markerPos  + 1&amp;#10;        sendTrigger(responseratingplus)" valType="extendedCode"/>
        <Param name="Each JS Frame" updates="constant" val="" valType="extendedCode"/>
        <Param name="End Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="End JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="End JS Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="End Routine" updates="constant" val="# check responses&amp;#10;if slider_resp_response.keys in ['', [], None]:  # No response was made&amp;#10;    slider_resp_response.keys = None&amp;#10;    sendTrigger(norating)&amp;#10;    &amp;#10;study.addData(&quot;Rating&quot;, slider.markerPos) #Save final Slider Position" valType="extendedCode"/>
        <Param name="disabled" updates="None" val="False" valType="bool"/>
        <Param name="name" updates="None" val="code_ex" valType="code"/>
      </CodeComponent>
    </Routine>
