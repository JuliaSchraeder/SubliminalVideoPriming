      <CodeComponent name="code_slider_study">
        <Param name="Before Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Before JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin JS Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin Routine" updates="constant" val="slider_resp_study.rt = []&amp;#10;_slider_resp_study_allKeys = []&amp;#10;slider_resp_study.keys = [] &amp;#10;&amp;#10;slider_stud.reset()&amp;#10;event.clearEvents('slider_resp_response')&amp;#10;slider_stud.markerPos = 5" valType="extendedCode"/>
        <Param name="Code Type" updates="None" val="Py" valType="str"/>
        <Param name="Each Frame" updates="constant" val="keys = slider_resp_study.getKeys(keyList=['7', '9'], waitRelease=False)&amp;#10;_slider_resp_study_allKeys.extend(keys) # put pressed keys in list&amp;#10;if len(keys) == 1:&amp;#10;    if len(_slider_resp_study_allKeys):&amp;#10;        slider_resp_study.keys = _slider_resp_study_allKeys[0].name  # just the first key pressed&amp;#10;        slider_resp_study.rt = _slider_resp_study_allKeys[0].rt #rt of first press&amp;#10;    if '7' in keys:&amp;#10;        slider_stud.markerPos = slider_stud.markerPos - 1&amp;#10;        sendTrigger(180)&amp;#10;    elif '9' in keys:&amp;#10;        slider_stud.markerPos = slider_stud.markerPos  + 1&amp;#10;        sendTrigger(190)" valType="extendedCode"/>
        <Param name="Each JS Frame" updates="constant" val="" valType="extendedCode"/>
        <Param name="End Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="End JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="End JS Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="End Routine" updates="constant" val="# check responses&amp;#10;if slider_resp_study.keys in ['', [], None]:  # No response was made&amp;#10;    slider_resp_study.keys = None&amp;#10;    sendTrigger(81)&amp;#10;    &amp;#10;study.addData(&quot;Rating&quot;, slider_stud.markerPos) #Save final Slider Position" valType="extendedCode"/>
        <Param name="disabled" updates="None" val="False" valType="bool"/>
        <Param name="name" updates="None" val="code_slider_study" valType="code"/>
      </CodeComponent>
      <KeyboardComponent name="slider_resp_study">
        <Param name="allowedKeys" updates="constant" val="'7','9'" valType="code"/>
        <Param name="correctAns" updates="constant" val="" valType="str"/>
        <Param name="disabled" updates="None" val="False" valType="bool"/>
